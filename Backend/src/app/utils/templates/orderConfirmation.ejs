<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: sans-serif; line-height: 1.6; color: #333; }
        .container { width: 80%; margin: 20px auto; padding: 20px; border: 1px solid #ddd; border-radius: 8px; }
        h1 { color: #2c3e50; }
        .order-details { margin-top: 20px; }
        .item { border-bottom: 1px solid #eee; padding: 10px 0; }
        .total { font-weight: bold; font-size: 1.2em; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Order Confirmation</h1>
        <p>Hello <%= name %>,</p>
        <p>Thank you for your order! Your payment has been successfully processed.</p>
        
        <div class="order-details">
            <p><strong>Order ID:</strong> <%= orderId %></p>
            <p><strong>Transaction ID:</strong> <%= transactionId %></p>
            
            <h3>Items:</h3>
            <% items.forEach(item => { %>
                <div class="item">
                    <p><%= item.name %> x <%= item.quantity %> - <%= item.price %> BDT</p>
                </div>
            <% }) %>
            
            <p class="total">Total Amount: <%= totalAmount %> BDT</p>
        </div>
        
        <p>We will notify you once your items are shipped.</p>
        <p>Best regards,<br>The Shopnest Team</p>
    </div>
</body>
</html>
